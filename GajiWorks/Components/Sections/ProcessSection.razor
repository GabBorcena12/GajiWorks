@{
    var steps = new[]
    {
        ("01", "Tell Us What You Need", "We discuss your business goals, target audience, needed pages, content, and priorities."),
        ("02", "Get a Clear Plan & Quote", "You receive a clear scope, timeline, pricing estimate, and what is included before work starts."),
        ("03", "Build, Test & Review", "The website or system is created, tested for responsiveness, forms, links, layout, and core functions, then reviewed with you for included revisions."),
        ("04", "Launch & Ongoing Support", "Once approved, the project is prepared for launch, turned over properly, and can be supported through optional monthly maintenance.")
    };
}

<section id="process" class="section section-anchor">
    <div class="container">
        <SectionHeading Eyebrow="Your Project Journey" Title="Four clear steps from idea to launch." Description="A simple, transparent process keeps you informed and involved from the first conversation through launch and support." />
        <div class="process-list client-journey">
            @foreach (var step in steps)
            {
                <article class="process-step reveal">
                    <span class="process-number">@step.Item1</span>
                    <div class="process-copy"><h3>@step.Item2</h3><p>@step.Item3</p></div>
                </article>
            }
        </div>
    </div>
</section>
